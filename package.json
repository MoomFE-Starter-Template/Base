{
  "name": "moomfe-base",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.6",
  "author": "Wei Zhang <https://github.com/Zhang-Wei-666>",
  "homepage": "https://github.com/MoomFE-Starter-Template/Base",
  "scripts": {
    "dev": "pnpm i && nuxt dev --host",
    "build": "pnpm i && nuxt generate",
    "build:ssr": "pnpm i && nuxt build",
    "preview": "pnpm build && nuxt preview --host",
    "preview:ssr": "pnpm build:ssr && nuxt preview --host",
    "lint": "pnpm i && eslint .",
    "lint:fix": "pnpm i && eslint . --fix",
    "test": "tsx ./cypress/scripts/run-test.ts",
    "test:ci": "tsx ./cypress/scripts/run-test.ts --ci",
    "up": "npx taze latest -w -i",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@mixte/snippets": "^2.5.0",
    "@mixte/use": "^2.5.0",
    "@primevue/themes": "^4.3.1",
    "@unocss/reset": "^0.64.1",
    "@vueuse/core": "^12.0.0",
    "@vueuse/math": "^12.0.0",
    "dayjs": "^1.11.13",
    "element-plus": "^2.9.5",
    "lodash-unified": "^1.0.3",
    "mixte": "^2.5.0",
    "pinia": "^2.3.1",
    "primevue": "^4.3.1",
    "theme-colors": "^0.1.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@element-plus/nuxt": "^1.1.1",
    "@iconify/json": "^2.2.310",
    "@moomfe/eslint-config": "^3.4.0",
    "@nuxtjs/color-mode": "^3.5.2",
    "@nuxtjs/i18n": "^8.5.6",
    "@pinia/nuxt": "^0.10.1",
    "@primevue/nuxt-module": "^4.3.1",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/picomatch": "^3.0.2",
    "@unocss/nuxt": "^0.64.1",
    "@vueuse/nuxt": "^12.0.0",
    "eslint": "^9.15.0",
    "fast-glob": "^3.3.3",
    "html-minifier-terser": "^7.2.0",
    "nuxt": "^3.14.1592",
    "pathe": "^1.1.2",
    "picomatch": "^4.0.2",
    "pnpm": "^9.15.6",
    "sass": "^1.85.1",
    "tsx": "^4.19.3",
    "type-fest": "^4.35.0",
    "typescript": "^5.7.3",
    "unocss": "^0.64.1",
    "unocss-preset-extra": "^0.5.3",
